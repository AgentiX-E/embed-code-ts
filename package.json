{
  "name": "agentix-embed-code-ts",
  "version": "0.1.0",
  "private": true,
  "description": "nomic-embed-code int8 ONNX weights in a TypeScript npm package \u2014 incbin-style",
  "workspaces": [
    "packages/embed-code-core",
    "packages/embed-code-cli"
  ],
  "scripts": {
    "build": "cd packages/embed-code-core && npx tsup",
    "build:cli": "cd packages/embed-code-cli && npx tsc",
    "build:all": "npm run build && npm run build:cli",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "clean": "rimraf packages/*/dist packages/*/tsconfig.tsbuildinfo coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "export:model": "python3 scripts/export-onnx.py --output models/nomic-embed-code-v1-int8.onnx",
    "pipeline": "node scripts/pipeline.js",
    "pipeline:export": "node scripts/pipeline.js --export",
    "pipeline:test": "node scripts/pipeline.js --test",
    "docs:generate": "typedoc",
    "changeset": "changeset",
    "prepare": "husky",
    "release": "node scripts/pipeline.js && gh release create v$(node -p \"require('./package.json').version\") models/nomic-embed-code-v1-int8.onnx models/model-descriptor.json --title \"nomic-embed-code v1 int8 ONNX\" --notes \"Pre-exported nomic-embed-code v1 int8 ONNX model for embed-code-ts.\""
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "rimraf": "^6.0.0",
    "tsx": "^4.0.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentiX-E/embed-code-ts"
  },
  "keywords": [
    "nomic",
    "embed-code",
    "code-embedding",
    "onnx",
    "int8",
    "typescript"
  ]
}
