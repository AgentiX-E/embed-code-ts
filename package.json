{
  "name": "@agentix-e/embed-code-ts",
  "version": "0.1.0",
  "description": "nomic-embed-code int8 ONNX weights embedded in a TypeScript npm package — incbin-style, zero network dependency at runtime",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/platform/node.d.ts",
      "import": "./dist/platform/node.js"
    },
    "./web": {
      "types": "./dist/platform/web.d.ts",
      "import": "./dist/platform/web.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:weights": "tsx scripts/build.ts",
    "build:all": "npm run build:weights && npm run build",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build:all",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "keywords": [
    "nomic",
    "embed-code",
    "code-embedding",
    "onnx",
    "int8",
    "quantized",
    "typescript",
    "incbin",
    "embedding",
    "semantic-search",
    "code-search",
    "vector-embedding"
  ],
  "author": "AgentiX-E",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentiX-E/embed-code-ts"
  },
  "peerDependencies": {
    "onnxruntime-node": "^1.20.0"
  },
  "peerDependenciesMeta": {
    "onnxruntime-node": {
      "optional": true
    },
    "onnxruntime-web": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
