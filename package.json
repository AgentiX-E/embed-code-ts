{
  "name": "agentix-embed-code-ts",
  "version": "0.1.1",
  "private": true,
  "description": "nomic-embed-code int8 weights in a TypeScript npm package — ONNX Runtime code embeddings for Node.js and browser",
  "workspaces": [
    "packages/embed-code-core",
    "packages/embed-code-node",
    "packages/embed-code-web",
    "packages/embed-code-cli"
  ],
  "scripts": {
    "build": "cd packages/embed-code-core && npx tsup",
    "build:cli": "cd packages/embed-code-cli && npx tsc",
    "build:node": "cd packages/embed-code-node && npx tsc",
    "build:web": "cd packages/embed-code-web && npx tsc",
    "build:all": "npm run build && npm run build:node && npm run build:web && npm run build:cli",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "clean": "rimraf packages/*/dist coverage",
    "ci": "npm run build && npm run lint && npm run format:check && npm run test:unit:coverage && node scripts/ci-coverage-check.js --tier unit --verbose",
    "ci:local": "npm run build && npm run lint && npm run format:check && npm run test:unit:coverage && node scripts/ci-coverage-check.js --tier unit --verbose",
    "ci:full": "npm run build:all && npm run lint && npm run format:check && npm run test:unit:coverage && node scripts/ci-coverage-check.js --tier unit --verbose && npm run test:coverage && node scripts/ci-coverage-check.js --tier integration --verbose",
    "precommit": "npm run lint && npm run format:check",
    "docs:generate": "typedoc",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "rimraf": "^6.0.0",
    "tsx": "^4.0.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentiX-E/embed-code-ts"
  },
  "homepage": "https://agentix-e.github.io/embed-code-ts/",
  "bugs": {
    "url": "https://github.com/AgentiX-E/embed-code-ts/issues"
  },
  "keywords": [
    "nomic",
    "embed-code",
    "code-embedding",
    "code-embeddings",
    "embedding",
    "embeddings",
    "int8",
    "quantized",
    "typescript",
    "pure-ts",
    "bert",
    "onnx",
    "onnx-runtime",
    "semantic-search",
    "code-search",
    "semantic-code-search",
    "vector-search",
    "rag",
    "retrieval-augmented-generation",
    "machine-learning",
    "ml",
    "transformer",
    "nlp",
    "natural-language-processing",
    "nodejs",
    "browser",
    "wasm",
    "webgpu",
    "ai",
    "artificial-intelligence",
    "offline",
    "privacy-first"
  ]
}
