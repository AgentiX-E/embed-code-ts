{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": [
    "packages/embed-code-core/src/**/*.ts",
    "packages/embed-code-core/src/**/*.d.ts",
    "packages/embed-code-core/test/**/*.ts",
    "packages/embed-code-cli/src/**/*.ts",
    "packages/embed-code-cli/test/**/*.ts",
    "packages/embed-code-core/tsup.config.ts",
    "*.config.ts"
  ],
  "exclude": ["node_modules", "dist", "coverage"]
}
